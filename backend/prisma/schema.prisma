generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model RolePermission {
  id     Int    @id @default(autoincrement())
  role   String
  module String
  action String
  @@unique([role, module, action])
}

model UserPermission {
  id      Int    @id @default(autoincrement())
  userId  Int
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  module  String
  action  String
  granted Boolean @default(true)
  @@unique([userId, module, action])
  @@index([userId])
}

model User {
  id             Int              @id @default(autoincrement())
  username       String           @unique
  name           String
  email          String           @default("")
  password       String
  role           String           @default("cashier")
  active         Boolean          @default(true)
  sales          Sale[]
  purchases      PurchaseOrder[]
  cashRegisters  CashRegister[]
  cashMovements  CashMovement[]
  userPermissions    UserPermission[]
  loyaltyTransactions LoyaltyTransaction[]
  expenses            Expense[]
  auditLogs           AuditLog[]
  priceHistoryChanges PriceHistory[]
  stockMovements         StockMovement[]
  inventoryAdjustments   InventoryAdjustment[]   @relation("CreatedAdjustments")
  approvedAdjustments    InventoryAdjustment[]   @relation("ApprovedAdjustments")
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
}

model Tax {
  id         Int       @id @default(autoincrement())
  name       String
  percentage Float
  isDefault  Boolean   @default(false)
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  products   Product[]
}

model Currency {
  id           Int      @id @default(autoincrement())
  code         String   @unique
  name         String
  symbol       String
  exchangeRate Float    @default(1)
  isBase       Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  sales        Sale[]
}

model Product {
  id             Int            @id @default(autoincrement())
  code           String         @unique
  barcode        String         @default("")
  name           String
  description    String         @default("")
  category       String         @default("")
  brand          String         @default("")
  vehicleType    String         @default("")
  oemNumber      String         @default("")
  buyPrice       Float          @default(0)
  sellPrice      Float          @default(0)
  wholesalePrice Float          @default(0)
  stock          Int            @default(0)
  minStock       Int            @default(5)
  location       String         @default("")
  defaultLocationId Int?
  defaultLocation    Location?  @relation("DefaultProductLocation", fields: [defaultLocationId], references: [id], onDelete: SetNull)
  imageUrl       String         @default("")
  active         Boolean        @default(true)
  taxId          Int?
  tax            Tax?           @relation(fields: [taxId], references: [id], onDelete: Restrict)
  saleItems      SaleItem[]
  purchaseItems  PurchaseItem[]
  vehicleLinks   ProductVehicle[]
  images         ProductImage[]
  returns        SaleReturnItem[]
  priceHistories PriceHistory[]
  productLocations   ProductLocation[]
  stockMovements     StockMovement[]
  inventoryAdjustmentItems InventoryAdjustmentItem[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  altText   String  @default("")
  sortOrder Int     @default(0)

  @@index([productId])
}

model Warehouse {
  id        Int        @id @default(autoincrement())
  name      String
  code      String     @unique
  address   String     @default("")
  isActive  Boolean    @default(true)
  locations Location[]
  adjustments InventoryAdjustment[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Location {
  id                Int               @id @default(autoincrement())
  warehouseId       Int
  warehouse         Warehouse         @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  parentId          Int?
  parent            Location?         @relation("LocationHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children          Location[]        @relation("LocationHierarchy")
  name              String
  code              String
  type              String            @default("BIN")
  barcode           String            @default("")
  sortOrder         Int               @default(0)
  isActive          Boolean           @default(true)
  defaultProducts   Product[]         @relation("DefaultProductLocation")
  productLocations  ProductLocation[]
  stockMovements    StockMovement[]
  adjustmentItems   InventoryAdjustmentItem[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([warehouseId, code])
  @@index([parentId])
}

model ProductLocation {
  id         Int      @id @default(autoincrement())
  productId  Int
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  locationId Int
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  stock      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([productId, locationId])
  @@index([locationId])
  @@index([productId])
}

model StockMovement {
  id            Int      @id @default(autoincrement())
  productId     Int
  product       Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  locationId    Int?
  location      Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  type          String
  quantity      Int
  beforeStock   Int
  afterStock    Int
  beforeLocStock Int?
  afterLocStock  Int?
  referenceType String?
  referenceId   Int?
  reason        String   @default("")
  userId        Int?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())

  @@index([productId])
  @@index([locationId])
  @@index([type])
  @@index([createdAt])
  @@index([referenceType, referenceId])
  @@index([userId])
}

model InventoryAdjustment {
  id           Int                      @id @default(autoincrement())
  type         String
  status       String                   @default("draft")
  warehouseId  Int
  warehouse    Warehouse                @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  notes        String                   @default("")
  createdById  Int
  createdBy    User                     @relation("CreatedAdjustments", fields: [createdById], references: [id], onDelete: Restrict)
  approvedById Int?
  approvedBy   User?                    @relation("ApprovedAdjustments", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt   DateTime?
  items        InventoryAdjustmentItem[]
  createdAt    DateTime                 @default(now())

  @@index([warehouseId])
  @@index([createdById])
  @@index([status])
  @@index([createdAt])
}

model InventoryAdjustmentItem {
  id           Int                  @id @default(autoincrement())
  adjustmentId Int
  adjustment   InventoryAdjustment  @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  productId    Int
  product      Product              @relation(fields: [productId], references: [id], onDelete: Restrict)
  locationId   Int
  location     Location             @relation(fields: [locationId], references: [id], onDelete: Restrict)
  expectedQty  Int                  @default(0)
  actualQty    Int                  @default(0)
  difference   Int                  @default(0)
  notes        String               @default("")

  @@index([adjustmentId])
  @@index([productId])
  @@index([locationId])
}

model Client {
  id                 Int                  @id @default(autoincrement())
  name               String
  phone              String               @default("")
  email              String               @default("")
  address            String               @default("")
  document           String               @default("")
  vehicle            String               @default("")
  notes              String               @default("")
  creditLimit        Float                @default(0)
  currentBalance     Float                @default(0)
  pointsBalance      Int                  @default(0)
  sales              Sale[]
  creditPayments     CreditPayment[]
  loyaltyTransactions LoyaltyTransaction[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([name])
  @@index([document])
}

model Supplier {
  id            Int             @id @default(autoincrement())
  name          String
  contact       String          @default("")
  phone         String          @default("")
  email         String          @default("")
  address       String          @default("")
  notes         String          @default("")
  purchases     PurchaseOrder[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Vehicle {
  id       Int             @id @default(autoincrement())
  brand    String
  model    String
  year     Int?
  products ProductVehicle[]
  createdAt DateTime @default(now())
}

model ProductVehicle {
  id        Int     @id @default(autoincrement())
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  vehicleId Int
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  @@unique([productId, vehicleId])
  @@index([vehicleId])
}

model Sale {
  id             Int            @id @default(autoincrement())
  invoiceNumber  String?        @unique
  clientId       Int?
  client         Client?        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  userId         Int
  user           User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  cashRegisterId Int?
  cashRegister   CashRegister?  @relation(fields: [cashRegisterId], references: [id], onDelete: SetNull)
  currencyId     Int?
  currency       Currency?      @relation(fields: [currencyId], references: [id], onDelete: Restrict)
  items          SaleItem[]
  creditPayments CreditPayment[]
  returns        SaleReturn[]
  subtotal       Float          @default(0)
  discount       Float          @default(0)
  tax            Float          @default(0)
  taxTotal       Float          @default(0)
  total          Float          @default(0)
  paymentMethod  String         @default("cash")
  paymentDetails String         @default("")
  status         String         @default("completed")
  cancelledAt    DateTime?
  cancelReason   String         @default("")
  pointsEarned   Int            @default(0)
  pointsRedeemed Int            @default(0)
  createdAt      DateTime       @default(now())

  @@index([userId])
  @@index([clientId])
  @@index([cashRegisterId])
  @@index([currencyId])
  @@index([status])
  @@index([paymentMethod])
  @@index([createdAt])
}

model SaleItem {
  id          Int      @id @default(autoincrement())
  saleId      Int
  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId   Int
  product     Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  productName String
  quantity    Int      @default(1)
  unitPrice   Float
  unitCost    Float?
  totalPrice  Float

  @@index([saleId])
  @@index([productId])
}

model SaleReturn {
  id               Int              @id @default(autoincrement())
  saleId           Int
  sale             Sale             @relation(fields: [saleId], references: [id], onDelete: Restrict)
  reason           String
  totalRefund      Float            @default(0)
  creditNoteNumber String           @default("")
  createdAt        DateTime         @default(now())
  items            SaleReturnItem[]

  @@index([saleId])
  @@index([createdAt])
}

model SaleReturnItem {
  id           Int        @id @default(autoincrement())
  saleReturnId Int
  saleReturn   SaleReturn @relation(fields: [saleReturnId], references: [id], onDelete: Cascade)
  productId    Int
  product      Product    @relation(fields: [productId], references: [id], onDelete: Restrict)
  productName  String
  quantity     Int
  unitPrice    Float
  subtotal     Float

  @@index([saleReturnId])
  @@index([productId])
}

model CreditPayment {
  id        Int      @id @default(autoincrement())
  saleId    Int
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Restrict)
  clientId  Int?
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: Restrict)
  amount    Float
  method    String   @default("cash")
  notes     String   @default("")
  createdAt DateTime @default(now())

  @@index([saleId])
  @@index([clientId])
  @@index([createdAt])
}

model CashRegister {
  id             Int             @id @default(autoincrement())
  userId         Int
  user           User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  openingBalance Float           @default(0)
  closingBalance Float?
  openingDate    DateTime        @default(now())
  closingDate    DateTime?
  status         String          @default("open")
  notes          String          @default("")
  sales          Sale[]
  movements      CashMovement[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model CashMovement {
  id             Int          @id @default(autoincrement())
  cashRegisterId Int
  cashRegister   CashRegister @relation(fields: [cashRegisterId], references: [id], onDelete: Cascade)
  userId         Int?
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  type           String       @default("income")
  amount         Float
  description    String
  reference      String       @default("")
  createdAt      DateTime     @default(now())

  @@index([cashRegisterId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model PurchaseOrder {
  id          Int            @id @default(autoincrement())
  supplierId  Int
  supplier    Supplier       @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  userId      Int
  user        User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  items       PurchaseItem[]
  subtotal    Float          @default(0)
  tax         Float          @default(0)
  total       Float          @default(0)
  status      String         @default("pending")
  invoiceFile String         @default("")
  createdAt   DateTime       @default(now())
  receivedAt  DateTime?

  @@index([supplierId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model PurchaseItem {
  id          Int           @id @default(autoincrement())
  purchaseId  Int
  purchase    PurchaseOrder @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId   Int
  product     Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  productName String
  quantity    Int
  unitCost    Float
  totalCost   Float

  @@index([purchaseId])
  @@index([productId])
}

model LoyaltyConfig {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model StoreConfig {
  id           Int      @id @default(1)
  companyName  String   @default("")
  description  String   @default("")
  rnc          String   @default("")
  address      String   @default("")
  phone        String   @default("")
  email        String   @default("")
  logoUrl      String   @default("")
  ncf          String   @default("")
  updatedAt    DateTime @updatedAt
}

model SystemConfig {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
  updatedAt DateTime @updatedAt
}

model LoyaltyTransaction {
  id            Int      @id @default(autoincrement())
  clientId      Int
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Restrict)
  type          String
  points        Int
  balanceBefore Int
  balanceAfter  Int
  referenceType String
  referenceId   String   @default("")
  description   String   @default("")
  createdById   Int
  createdBy     User     @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt     DateTime @default(now())
  expiresAt     DateTime?

  @@index([clientId])
  @@index([createdAt])
  @@index([createdById])
  @@index([type])
}

model Expense {
  id            Int      @id @default(autoincrement())
  description   String
  amount        Float
  category      String   @default("other")
  paymentMethod String   @default("cash")
  reference     String   @default("")
  notes         String   @default("")
  attachmentUrl String   @default("")
  taxAmount     Float    @default(0)
  taxDeductible Boolean  @default(true)
  userId        Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([category])
  @@index([createdAt])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  Int?
  metadata  Json?
  ip        String   @default("")
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

model PriceHistory {
  id          Int      @id @default(autoincrement())
  productId   Int
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  field       String
  oldValue    Float
  newValue    Float
  changedById Int?
  changedBy   User?    @relation(fields: [changedById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([productId])
  @@index([createdAt])
  @@index([changedById])
}
