{
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    }
  },
  "buildCommand": "npm install && npx prisma generate && npx prisma db push && npm run build",
  "installCommand": "npm install",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/(.*)", "destination": "/api" }
  ]
}
